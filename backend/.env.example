APP_NAME=Laravel
APP_ENV=local
# Run `php artisan key:generate` — required for Passport tokens and encryption (empty APP_KEY causes HTTP 500 on platform login).
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_APP_URL=http://localhost:3001

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=central
DB_HOST=127.0.0.1
# MySQL port for landlord DB (central).
# Docker: `npm run dev` uses backend/.env.docker (DB_HOST=mysql). Host-only: port 3307 — env.docker.example
CENTRAL_DB_PORT=3307
DB_PORT=3307
DB_DATABASE=toweros
DB_USERNAME=root
DB_PASSWORD=toweros

TENANCY_CENTRAL_CONNECTION=central
CENTRAL_DOMAINS=127.0.0.1,localhost
# Local: allow tenant API on central host via X-Tenant-Id (UUID) or X-Tenant-Domain (must match Origin in production).
# Production: set false unless all callers are trusted (prefer same-hostname API or edge routing so Host resolves the tenant).
TOWEROS_ALLOW_TENANT_ON_CENTRAL_HOST=true
# Production defaults (when APP_ENV=production): HTTPS required for X-Tenant-Domain; Origin/Referer host must match header.
# TOWEROS_TENANT_CENTRAL_DOMAIN_HEADER_REQUIRE_HTTPS=true
# TOWEROS_TENANT_CENTRAL_DOMAIN_HEADER_REQUIRE_ORIGIN=true
TENANCY_QUEUE_DATABASE_PROVISIONING=false
# After git pull / deploy with new migrations: php artisan toweros:migrate
# Orphan tenant row without MySQL DB: php artisan toweros:repair-tenant-databases
# (New tenants still auto-migrate on create via Stancl — this is for central + existing tenants.)

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# Soketi / Pusher (set BROADCAST_CONNECTION=pusher when running Soketi locally)
PUSHER_APP_ID=toweros-local
PUSHER_APP_KEY=toweros-local
PUSHER_APP_SECRET=toweros-local-secret
PUSHER_HOST=127.0.0.1
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1
FILESYSTEM_DISK=local
# Use redis when Redis is running (required for Horizon / multi-worker queues). Otherwise sync + database cache work locally.
QUEUE_CONNECTION=sync

CACHE_STORE=database
# Keep permission cache independent from Redis during local bootstrap.
PERMISSION_CACHE_STORE=array
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- TowerOS (central API + Passport + Horizon) ---
PASSPORT_ACCESS_TOKEN_TTL_HOURS=12
PASSPORT_REFRESH_TOKEN_TTL_DAYS=30
# PASSPORT_CONNECTION=
# PASSPORT_PATH=oauth
# Platform login (Passport personal tokens): `php artisan db:seed` creates the client if missing, or run:
# php artisan passport:client --personal --name="TowerOS Personal Access Client" --provider=users

# Optional extra Sanctum stateful domains (comma-separated). Tenant hostnames from the
# central database (domains + tenant_domain_endpoints) are merged automatically on boot.
SANCTUM_STATEFUL_DOMAINS=
# TOWEROS_SANCTUM_STATEFUL_CACHE_TTL=3600
TENANT_ACCESS_TOKEN_TTL_MINUTES=60
TENANT_REFRESH_TOKEN_TTL_DAYS=30
# Global MFA gate for tenant users. When false, MFA is off for all tenants. When true, each tenant can still opt out via platform console (tenants.mfa_required).
TENANT_MFA_REQUIRED=true
TENANT_SSO_DEFAULT_ROLE=viewer

AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI="${APP_URL}/api/v1/auth/microsoft/callback"
AZURE_TENANT_ID=common

HORIZON_PATH=horizon
# HORIZON_DOMAIN=

TOWEROS_QUEUE_DEFAULT=toweros-default
TOWEROS_QUEUE_TENANT=toweros-tenant
TOWEROS_QUEUE_NOTIFICATIONS=toweros-notifications
TOWEROS_QUEUE_INTEGRATIONS=toweros-integrations
TOWEROS_QUEUE_WEBHOOKS=toweros-webhooks

# Optional fixed password for every new tenant's admin@{domain} (otherwise random).
# TOWEROS_TENANT_BOOTSTRAP_ADMIN_PASSWORD=
# TOWEROS_TENANT_BOOTSTRAP_ADMIN_NAME="Tenant administrator"
# In production, generated bootstrap passwords are omitted from the provisioning API by default. Set true only temporarily.
# TOWEROS_TENANT_BOOTSTRAP_EXPOSE_PASSWORD_IN_API=true

# Central Passport platform console (DatabaseSeeder). Change in production.
TOWEROS_PLATFORM_SUPER_ADMIN_EMAIL=superadmin@toweros.local
TOWEROS_PLATFORM_DEV_PASSWORD=123123123

ACTIVITY_LOGGER_ENABLED=true

# New tenant provisioning (platform console)
TOWEROS_TENANT_DEFAULT_PLAYBOOK=latest
TOWEROS_TENANT_AUTO_SEED_HOLIDAYS=true
TOWEROS_TENANT_SEED_NEXT_HOLIDAY_YEAR=true

# Tenant rollout file uploads (SAQ/CME evidence)
TOWEROS_TENANT_FILES_DISK=tenant_files
TOWEROS_TENANT_FILES_MAX_KB=10240
# TOWEROS_DEMO_SEED=false