# =============================================================================
# TowerOS environment template
# =============================================================================
# LOCAL (host PHP / artisan):
#   Copy to backend/.env · DB_HOST=127.0.0.1 · DB_PORT=3307 · APP_URL=http://localhost:8000
#
# LOCAL (Docker — recommended):
#   Use backend/.env.docker · docker compose --env-file .env.docker
#   DB_HOST=mysql · APP_URL=http://localhost:8000
#
# PRODUCTION:
#   Copy backend/.env.production.example → server .env · APP_ENV=production · APP_DEBUG=false
# =============================================================================

APP_NAME=TowerOS
APP_ENV=local
# Run `php artisan key:generate` — required for Passport tokens and encryption (empty APP_KEY causes HTTP 500 on platform login).
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_APP_URL=http://localhost:3000
# Explicit CORS allowlist (merged with tenant hostnames from the central DB at runtime).
# Local (APP_ENV=local): defaults to http://*.localhost so tenant UIs like http://atc.localhost can call the API.
# TOWEROS_CORS_ALLOWED_ORIGINS=https://platform.yourdomain.com
# TOWEROS_CORS_ALLOWED_ORIGIN_PATTERNS=https://*.yourdomain.com
# Tenant UI base URL for approval emails and deep links (defaults to FRONTEND_APP_URL).
# Docker/staging: use the hostname you open in the browser, e.g. http://staging.atc.localhost
# TOWEROS_TENANT_APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=central
DB_HOST=127.0.0.1
# MySQL port for landlord DB (central).
# Docker: `npm run dev` uses backend/.env.docker (DB_HOST=mysql). Host-only: port 3307 — env.docker.example
CENTRAL_DB_PORT=3307
DB_PORT=3307
DB_DATABASE=toweros
DB_USERNAME=root
DB_PASSWORD=toweros

TENANCY_CENTRAL_CONNECTION=central
CENTRAL_DOMAINS=127.0.0.1,localhost
# Local: allow tenant API on central host via X-Tenant-Id (UUID) or X-Tenant-Domain (must match Origin in production).
# Production: set false unless all callers are trusted (prefer same-hostname API or edge routing so Host resolves the tenant).
TOWEROS_ALLOW_TENANT_ON_CENTRAL_HOST=true

# Tenant admin "view as user" (requires user:impersonate; granted to tenant_admin by default).
TOWEROS_TENANT_IMPERSONATION_ENABLED=true
TOWEROS_TENANT_IMPERSONATION_TTL_MINUTES=30
# Superadmin console "view as tenant user" (platform operators only).
TOWEROS_PLATFORM_IMPERSONATION_ENABLED=true
TOWEROS_PLATFORM_IMPERSONATION_TTL_MINUTES=30
# Platform console Microsoft SSO callback lands on FRONTEND_APP_URL/platform/login/microsoft-callback
# TOWEROS_PLATFORM_ENTRA_AUTO_PROVISION=false
# TOWEROS_PLATFORM_ENTRA_GROUP_ROLE_MAP={"<entra-group-id>":"support"}
# Optional: auto-provision one dev tenant after db:seed (any hostname you use in the browser).
# TOWEROS_SEED_DEV_DEFAULT_TENANT=true
# TOWEROS_DEV_DEFAULT_TENANT_DOMAIN=acme.localhost
# TOWEROS_DEV_DEFAULT_TENANT_SLUG=acme
# Production defaults (when APP_ENV=production): HTTPS required for X-Tenant-Domain; Origin/Referer host must match header.
# TOWEROS_TENANT_CENTRAL_DOMAIN_HEADER_REQUIRE_HTTPS=true
# TOWEROS_TENANT_CENTRAL_DOMAIN_HEADER_REQUIRE_ORIGIN=true
TENANCY_QUEUE_DATABASE_PROVISIONING=false
# After git pull / deploy with new migrations: php artisan toweros:migrate
# Orphan tenant row without MySQL DB: php artisan toweros:repair-tenant-databases
# (New tenants still auto-migrate on create via Stancl — this is for central + existing tenants.)

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# Soketi / Pusher (set BROADCAST_CONNECTION=pusher when running Soketi locally)
PUSHER_APP_ID=toweros-local
PUSHER_APP_KEY=toweros-local
PUSHER_APP_SECRET=toweros-local-secret
PUSHER_HOST=127.0.0.1
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1
FILESYSTEM_DISK=local
# Use redis when Redis is running (required for Horizon / multi-worker queues). Otherwise sync + database cache work locally.
QUEUE_CONNECTION=sync

CACHE_STORE=redis
# Stancl tenancy cache tags: auto-on for redis/memcached only (off for database/file local dev).
# TENANCY_CACHE_BOOTSTRAPPER=true
PERMISSION_CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# Module notifications (E-Approval, Project One gates): smtp (Microsoft 365), ses (AWS), log (local only)
# Local Docker + Mailpit (UI http://localhost:8025, SMTP port 1025):
# TOWEROS_NOTIFICATIONS_MAIL_MAILER=smtp
# MAIL_MAILER=smtp
# MAIL_HOST=host.docker.internal
# MAIL_PORT=1025
# MAIL_ENCRYPTION=null
# MAIL_HOST=smtp.office365.com
# MAIL_PORT=587
# MAIL_USERNAME=noreply@yourdomain.com
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- TowerOS (central API + Passport + Horizon) ---
PASSPORT_ACCESS_TOKEN_TTL_HOURS=12
PASSPORT_REFRESH_TOKEN_TTL_DAYS=30
# PASSPORT_CONNECTION=
# PASSPORT_PATH=oauth
# Platform login (Passport personal tokens): `php artisan db:seed` creates the client if missing, or run:
# php artisan passport:client --personal --name="TowerOS Personal Access Client" --provider=users

# Optional extra Sanctum stateful domains (comma-separated). Tenant hostnames from the
# central database (domains + tenant_domain_endpoints) are merged automatically on boot.
SANCTUM_STATEFUL_DOMAINS=
# TOWEROS_SANCTUM_STATEFUL_CACHE_TTL=3600
TENANT_ACCESS_TOKEN_TTL_MINUTES=60
TENANT_REFRESH_TOKEN_TTL_DAYS=30
# Master MFA switch (off by default). Per-tenant: platform console → tenant → mfa_required.
TENANT_MFA_REQUIRED=false
TOWEROS_TENANT_DEFAULT_MFA_REQUIRED=false
# Require TOTP MFA for central platform operators (Superadmin console).
TOWEROS_PLATFORM_MFA_REQUIRED=false
# Structured JSON audit mirror for Loki / OpenSearch / CloudWatch (see LOG_AUDIT_* below).
TOWEROS_AUDIT_STRUCTURED_ENABLED=true
TOWEROS_AUDIT_LOG_CHANNEL=audit
LOG_AUDIT_STACK=audit_daily,audit_stderr
LOG_AUDIT_DAYS=365
# --- Billing (LOCAL: Stripe usually off; PRODUCTION: see .env.production.example) ---
TOWEROS_BILLING_SUPPORT_EMAIL=support@toweros.local
TOWEROS_TENANT_DEFAULT_PLAN_TIER=professional
TOWEROS_SUBSCRIPTION_DEFAULT_STATUS=active
TOWEROS_SUBSCRIPTION_TRIAL_DAYS=14
TOWEROS_SUBSCRIPTION_PAST_DUE_GRACE_DAYS=7
TOWEROS_SUBSCRIPTION_ON_TRIAL_EXPIRE=active
TOWEROS_STRIPE_ENABLED=false
# STRIPE_SECRET=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_PROFESSIONAL=
# STRIPE_PRICE_ENTERPRISE=
TOWEROS_BILLING_CURRENCY=USD
TOWEROS_LIST_PRICE_STARTER_USD=0
TOWEROS_LIST_PRICE_PROFESSIONAL_USD=99
TOWEROS_LIST_PRICE_ENTERPRISE_USD=299
# SSO: auto-create users on first Microsoft sign-in (default false). Disable password for non-break-glass when SSO on (default true).
TOWEROS_TENANT_DEFAULT_SSO_AUTO_PROVISION=false
TOWEROS_TENANT_DEFAULT_DISABLE_PASSWORD_WHEN_SSO=true
# Comma-separated roles for first Microsoft sign-in auto-provision (E-Approval requestor + Ticketing contributor).
TENANT_SSO_DEFAULT_ROLES=e_approval_requestor,ticketing_contributor
# Legacy single-role override (used only when TENANT_SSO_DEFAULT_ROLES is unset):
# TENANT_SSO_DEFAULT_ROLE=viewer

HORIZON_PATH=horizon
# HORIZON_DOMAIN=

TOWEROS_QUEUE_DEFAULT=toweros-default
TOWEROS_QUEUE_TENANT=toweros-tenant
# Enabled product modules for new tenants (comma-separated). Per-tenant Microsoft Entra: Administration → Tenant settings.
# Deployment-wide module catalog. Superadmin can override per tenant in Platform console.
TOWEROS_TENANT_ENABLED_MODULES=core,team_access,project_one,e_approval,ticketing,procurement_one,finance_one,sites,documents,document_register

TOWEROS_QUEUE_NOTIFICATIONS=toweros-notifications
# E-Approval + Project One gate emails (Microsoft 365: smtp; production: ses). Not legacy formbuilder mail.
# TOWEROS_NOTIFICATIONS_MAIL_MAILER=smtp
TOWEROS_QUEUE_INTEGRATIONS=toweros-integrations
TOWEROS_QUEUE_WEBHOOKS=toweros-webhooks

# Optional fixed password for every new tenant's admin@{domain} (otherwise random).
# TOWEROS_TENANT_BOOTSTRAP_ADMIN_PASSWORD=
# TOWEROS_TENANT_BOOTSTRAP_ADMIN_NAME="Tenant administrator"
# In production, generated bootstrap passwords are omitted from the provisioning API by default. Set true only temporarily.
# TOWEROS_TENANT_BOOTSTRAP_EXPOSE_PASSWORD_IN_API=true

# Central Passport platform console (DatabaseSeeder). Change in production.
TOWEROS_PLATFORM_SUPER_ADMIN_EMAIL=superadmin@toweros.local
TOWEROS_PLATFORM_DEV_PASSWORD=123123123

ACTIVITY_LOGGER_ENABLED=true

# New tenant provisioning (platform console)
TOWEROS_TENANT_DEFAULT_PLAYBOOK=latest
TOWEROS_TENANT_AUTO_SEED_HOLIDAYS=true
TOWEROS_TENANT_SEED_NEXT_HOLIDAY_YEAR=true

# Tenant rollout file uploads (SAQ/CME evidence)
TOWEROS_TENANT_FILES_DISK=tenant_files
TOWEROS_TENANT_FILES_MAX_KB=10240
# Site binder documents (Phase 1). Use s3 in staging/prod with AWS_* vars below.
TOWEROS_DOCUMENTS_MAX_KB=51200
TOWEROS_DOCUMENTS_GATE_ENFORCEMENT=true
# Direct-to-S3 presigned uploads for large/CAD files (requires TOWEROS_TENANT_FILES_DISK=s3).
TOWEROS_DOCUMENTS_PRESIGNED_UPLOAD=true
TOWEROS_DOCUMENTS_PRESIGNED_TTL_MINUTES=15
TOWEROS_DOCUMENTS_PRESIGNED_MIN_KB=10240

# Daily in-app alerts for documents expiring in 90/60/30 day windows (documents:expiry-notify).

# RFQ vendor portal — reminder emails N days before bidding_closes_at (procurement:rfq-reminders).
PROCUREMENT_RFQ_REMINDER_DAYS=3,1
# TOWEROS_TENANT_FILES_DISK=s3
# TOWEROS_DEMO_SEED=false