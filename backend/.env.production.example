# =============================================================================
# TowerOS — PRODUCTION (copy to .env on the server; never commit real secrets)
# =============================================================================
# Use with: APP_ENV=production, APP_DEBUG=false, HTTPS URLs, strong passwords.
# Docker ECS: inject via secrets manager / task definition env, not this file in git.

APP_NAME=TowerOS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.yourdomain.com
FRONTEND_APP_URL=https://app.yourdomain.com
TOWEROS_TENANT_APP_URL=https://app.yourdomain.com
TOWEROS_CORS_ALLOWED_ORIGIN_PATTERNS=https://*.yourdomain.com

LOG_LEVEL=warning

DB_CONNECTION=central
DB_HOST=your-aurora-host
CENTRAL_DB_PORT=3306
DB_PORT=3306
DB_DATABASE=toweros
DB_USERNAME=
DB_PASSWORD=

TENANCY_CENTRAL_CONNECTION=central
CENTRAL_DOMAINS=api.yourdomain.com
TOWEROS_ALLOW_TENANT_ON_CENTRAL_HOST=false
TOWEROS_TENANT_CENTRAL_DOMAIN_HEADER_REQUIRE_HTTPS=true
TOWEROS_TENANT_CENTRAL_DOMAIN_HEADER_REQUIRE_ORIGIN=true

SESSION_DRIVER=database
SESSION_ENCRYPT=true
QUEUE_CONNECTION=redis
CACHE_STORE=redis
REDIS_HOST=your-elasticache-host
REDIS_PASSWORD=

BROADCAST_CONNECTION=pusher
MAIL_MAILER=ses
TOWEROS_NOTIFICATIONS_MAIL_MAILER=ses

# --- Billing (Phases 1–5) ---
TOWEROS_BILLING_SUPPORT_EMAIL=billing@yourdomain.com
TOWEROS_TENANT_DEFAULT_PLAN_TIER=starter
TOWEROS_SUBSCRIPTION_DEFAULT_STATUS=active
TOWEROS_SUBSCRIPTION_TRIAL_DAYS=14
TOWEROS_SUBSCRIPTION_PAST_DUE_GRACE_DAYS=7
TOWEROS_SUBSCRIPTION_ON_TRIAL_EXPIRE=active

# Stripe: enable only when live keys + webhook are configured
TOWEROS_STRIPE_ENABLED=false
# STRIPE_SECRET=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PROFESSIONAL=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# Revenue dashboard list prices (indicative only — not invoicing)
TOWEROS_BILLING_CURRENCY=USD
TOWEROS_LIST_PRICE_STARTER_USD=0
TOWEROS_LIST_PRICE_PROFESSIONAL_USD=99
TOWEROS_LIST_PRICE_ENTERPRISE_USD=299

# Security
TOWEROS_TENANT_IMPERSONATION_ENABLED=false
TOWEROS_TENANT_BOOTSTRAP_EXPOSE_PASSWORD_IN_API=false
TOWEROS_PLATFORM_SUPER_ADMIN_EMAIL=ops@yourdomain.com
# Set a strong platform password via secret store — do not use dev defaults

TOWEROS_TENANT_ENABLED_MODULES=core,team_access,project_one,e_approval,ticketing
TOWEROS_TENANT_DEFAULT_MFA_REQUIRED=true
