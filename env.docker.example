# Copy to `.env.docker` at repo root (used by docker compose for ports + MySQL credentials).
# Default: `npm run dev` — MySQL + API + Soketi in Podman/Docker; web on host (`npm run dev:web`).
# Optional web container: `npm run dev:docker:full` (needs 8 GB+ VM RAM for dev mode).

TOWEROS_MYSQL_PORT=3307
TOWEROS_PHPMYADMIN_PORT=8080
TOWEROS_API_PORT=8000
TOWEROS_WEB_PORT=80
TOWEROS_DOCKER_AUTO_MIGRATE=1

# Container engine: auto | podman | docker (see docs/podman-desktop-setup.md)
TOWEROS_CONTAINER_CLI=podman

# --- Resource tuning (local Docker Desktop) ---
#
# Default TOWEROS_WEB_MODE=dev (hot reload). Web container needs ~3 GB RAM.
# Prod mode (`TOWEROS_WEB_MODE=prod`) only after `cd frontend && npm run build` succeeds.
# Web on host (recommended): Terminal 2 — `npm run dev:web` or `npm run dev:hybrid` (starts core + web).
TOWEROS_WEB_MODE=dev
TOWEROS_WEB_MEM_LIMIT=4g
NODE_OPTIONS=--max-old-space-size=1536
# Concurrent API workers (php artisan serve behind nginx). Use 4 for fast local
# parallel requests; each worker adds ~150-250 MB RAM.
TOWEROS_API_MEM_LIMIT=1g
TOWEROS_API_WORKERS=4
TOWEROS_MYSQL_MEM_LIMIT=768m
# Optional phpMyAdmin (adds ~250 MB): COMPOSE_PROFILES=tools

MYSQL_ROOT_PASSWORD=toweros
MYSQL_DATABASE=toweros
MYSQL_USER=toweros
MYSQL_PASSWORD=toweros
