# Copy to `.env.docker` at repo root (used by docker compose for ports + MySQL credentials).
# Full stack: `npm run dev` — API, Web, MySQL, phpMyAdmin (no dev.cmd required).

TOWEROS_MYSQL_PORT=3307
TOWEROS_PHPMYADMIN_PORT=8080
TOWEROS_API_PORT=8000
TOWEROS_WEB_PORT=80
TOWEROS_DOCKER_AUTO_MIGRATE=1

# --- Resource tuning (small Docker Desktop / ~6–8 GB RAM hosts) ---
# Use production Next.js in Docker to cut web memory from ~4 GB (dev) to ~300–500 MB.
# Rebuild after frontend changes: docker compose --env-file .env.docker exec web npm run build
TOWEROS_WEB_MODE=prod
# Dev mode only: cap Node heap (uncomment if TOWEROS_WEB_MODE=dev)
# NODE_OPTIONS=--max-old-space-size=2560
# Fewer PHP workers = less API RAM (default in compose is 2)
TOWEROS_API_WORKERS=2
# Optional: enable phpMyAdmin profile (disabled by default on small hosts)
# COMPOSE_PROFILES=tools

MYSQL_ROOT_PASSWORD=toweros
MYSQL_DATABASE=toweros
MYSQL_USER=toweros
MYSQL_PASSWORD=toweros
